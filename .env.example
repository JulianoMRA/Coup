# ============================================================================
# ATENCAO: os valores abaixo sao PLACEHOLDERS de exemplo.
# NAO os copie literalmente para a producao — substitua pelas URLs reais
# geradas pela Vercel (frontend) e pelo Railway (backend).
# ============================================================================

# ----------------------------------------------------------------------------
# Backend (Railway)
# ----------------------------------------------------------------------------
# PORT e injetada automaticamente pelo Railway — nao defina manualmente.
#
# FRONTEND_URL: origem(ns) aceita(s) pelo CORS. Pode ser:
#  - uma URL unica:  https://seu-app.vercel.app
#  - uma lista separada por virgula:  https://a.vercel.app,https://b.vercel.app
#  - com wildcard usando *:  https://seu-app-*-time.vercel.app
#    (o * casa apenas [a-zA-Z0-9-]+, seguro para os hashes de deploy da Vercel)
#
# Exemplo recomendado cobrindo producao + preview deploys da Vercel:
#   FRONTEND_URL=https://seu-app.vercel.app,https://seu-app-*-seu-time.vercel.app
FRONTEND_URL=https://SEU-APP-NA-VERCEL.vercel.app
NODE_ENV=production

# ----------------------------------------------------------------------------
# Frontend (Vercel)
# ----------------------------------------------------------------------------
# IMPORTANTE: variaveis NEXT_PUBLIC_* sao embeddadas no bundle durante o
# `next build`. Mudar o valor na Vercel NAO basta — e preciso disparar um
# novo deploy (Redeploy) para o novo valor entrar em vigor.
#
# Aponta para o dominio publico do servico backend no Railway.
# O codigo sanitiza trailing slashes, mas por convencao nao inclua.
NEXT_PUBLIC_BACKEND_URL=https://SEU-BACKEND.up.railway.app
